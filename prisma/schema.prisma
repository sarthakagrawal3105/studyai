generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id          String   @id @default(cuid())
  email       String?  @unique
  phoneNumber String?  @unique
  name        String?
  level     Int      @default(1)
  exp       Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  subjects  Subject[]
  sessions  StudySession[]
  tests     Test[]
  notes     Note[]
}

model Subject {
  id          String   @id @default(cuid())
  userId      String
  name        String
  color       String?
  totalWeeks  Int?
  targetHours Int?
  createdAt   DateTime @default(now())
  
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  topics      Topic[]
}

model Topic {
  id          String   @id @default(cuid())
  subjectId   String
  name        String
  description String?
  weekNumber  Int?
  estimatedHours Int?
  activeLearningStrategy String?
  isCompleted Boolean  @default(false)
  confidence  Int      @default(0) // 0-100%
  originalTopicId String?
  
  subject     Subject  @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  tests       Test[]
}

model StudySession {
  id        String   @id @default(cuid())
  userId    String
  duration  Int      // in minutes
  focus     Int      // 0-100% focus score
  date      DateTime @default(now())
  
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Test {
  id        String   @id @default(cuid())
  userId    String
  topicId   String?
  title     String
  score     Int?     // percentage
  createdAt DateTime @default(now())
  
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  topic     Topic?   @relation(fields: [topicId], references: [id], onDelete: Cascade)
  questions Question[]
}

model Question {
  id            String   @id @default(cuid())
  testId        String
  questionText  String
  options       String   // Stored as JSON string
  correctAnswer String
  userAnswer    String?
  isCorrect     Boolean?
  explanation   String?
  
  test          Test     @relation(fields: [testId], references: [id], onDelete: Cascade)
}

model Note {
  id        String   @id @default(cuid())
  userId    String
  title     String
  content   String
  createdAt DateTime @default(now())
  
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}
